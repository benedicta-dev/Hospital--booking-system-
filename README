└── Jenkinsfile
1. User Entity
Java
@Entity
@Table(name="users")
public class User {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private String fullName;

    @Column(unique=true)
    private String email;

    private String password;

    @Enumerated(EnumType.STRING)
    private Role role;
}
Java
public enum Role {
    PATIENT,
    DOCTOR,
    ADMIN
}
