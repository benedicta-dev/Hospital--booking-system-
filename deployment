YAML
apiVersion: apps/v1
kind: Deployment

metadata:
  name: hospital-backend

spec:
  replicas: 3

  selector:
    matchLabels:
      app: hospital

  template:
    metadata:
      labels:
        app: hospital

    spec:
      containers:
      - name: backend
        image: hospital-backend:latest

        ports:
        - containerPort: 8080
