Groovy
pipeline {

 agent any

 stages {

  stage('Build'){
   steps{
    sh 'mvn clean package'
   }
  }

  stage('Test'){
   steps{
    sh 'mvn test'
   }
  }

  stage('Docker'){
   steps{
    sh 'docker build -t hospital-app .'
   }
  }

  stage('Deploy'){
   steps{
    sh 'kubectl apply -f k8s/'
   }
  }
 }
}
